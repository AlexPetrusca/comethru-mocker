{
  "name": "client",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --port 8091 --dev-client",
    "android": "expo start --android --port 8091 --dev-client",
    "ios": "expo start --ios --port 8091 --dev-client",
    "web": "expo start --web --port 8091",
    "desktop": "expo start --web --port 8091 --no-dev",
    "build-android": "eas build --profile development --platform android --local --output ./build/android.apk",
    "build-ios": "eas build --profile development-simulator --platform ios --local --output ./build/ios.tar.gz",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.28",
    "axios": "^1.6.0",
    "expo": "~55.0.5",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.16",
    "expo-device": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-notifications": "~55.0.12",
    "expo-router": "~55.0.5",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-web-browser": "~55.0.9",
    "nativewind": "^4.2.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-keyboard-controller": "^1.21.0-beta.3",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-sse": "^1.2.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "expo": {
    "router": {
      "root": "src/app"
    }
  },
  "private": true
}
